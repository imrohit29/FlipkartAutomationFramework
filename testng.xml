<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Flipkart E-Commerce Automation Suite" parallel="tests" thread-count="2">

    <!-- Global Listeners -->
    <listeners>
        <listener class-name="listeners.TestListener" />
        <!-- Optionally you can register AnnotationTransformer if not registered programmatically -->
    </listeners>

    <test name="E-Commerce Core Flow Validation">
        <!-- Optional parameters can be provided from Pom.xml or jenkins -->
        <parameter name="browser" value="chrome"/>
        
        <classes>
            <class name="tests.LoginTest" />
            <class name="tests.SearchTest" />
            <class name="tests.FilterTest" />
            <class name="tests.CartTest" />
            <class name="tests.WishlistTest" />
            <class name="tests.CheckoutTest" />
        </classes>
    </test>

    <test name="Monitoring & Validation Suite">
        <parameter name="browser" value="chrome"/>
        
        <classes>
            <class name="tests.PriceMonitorTest" />
            <class name="tests.BrokenLinkTest" />
            <class name="tests.DBValidationTest" />
        </classes>
    </test>

    <!-- Cross browser suite demo -->
    <test name="Cross Browser Test - Firefox">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="tests.CrossBrowserTest" />
        </classes>
    </test>

</suite>
